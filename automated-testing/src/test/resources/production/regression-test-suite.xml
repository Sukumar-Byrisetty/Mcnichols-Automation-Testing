<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd" >

<suite name="Production Regression Test" verbose="1">
	<parameter name="env" value="prod" />
	<parameter name="base.url" value="https://www.mcnichols.com/" />
	<parameter name="browser.name" value="chrome" /> <!-- Browser names: chrome, firefox -->
	<parameter name="browser.viewport" value="XL" /> <!-- Browser viewport options: XL, L, S, XS -->

	<test name="Production - Place Order for Registered User" preserve-order="true">
   		<classes>
			<class name="com.mcnichols.tests.production.PlaceOrderForRegisteredUser"></class>
   		</classes>
  	</test>
  	
  	<test name="Production - Place Quote for Registered User" preserve-order="true">
   		<classes>
			<class name="com.mcnichols.tests.production.PlaceQuoteForRegisteredUser"></class>
   		</classes>
  	</test>

  	<test name="Production - Place Quote for Guest User" preserve-order="true">
   		<classes>
			<class name="com.mcnichols.tests.production.PlaceQuoteForGuestUser"></class>
   		</classes>
  	</test>
  	
  	<test name="Production - Browse and Search Test" preserve-order="true">
   		<classes>
			<class name="com.mcnichols.tests.BrowseAndSearchTest"></class>
   		</classes>
  	</test>

  	<test name="Production - Product Page Trench Drain Test" preserve-order="true">
  		<parameter name="product.path" value="/trench-drain-systems/polycast-sup-reg-sup-system/polymer-concrete-f3pc188820" />
   		<classes>
			<class name="com.mcnichols.tests.sandbox.ProductPageTest"></class>
   		</classes>
  	</test>

  	<test name="Production - Verify Stair Treads Category Product Links Test" preserve-order="true">
  		<parameter name="category.path" value="/stair-treads" />
   		<classes>
			<class name="com.mcnichols.tests.VerifyPagesFromCategoryPage"></class>
   		</classes>
  	</test>
  	
  	<test name="Production - Site Map Page Test" preserve-order="true">
  		<parameter name="sitemap" value="/site-map"></parameter>
   		<classes>
			<class name="com.mcnichols.tests.SitemapPage"></class>
   		</classes>
  	</test>
  	
  	<test name="Production - My Account - Credit Card Page Test" preserve-order="true">
  		<parameter name="accountlanding" value="/account/account-landing.jsp"></parameter>
		<parameter name="accountCC" value="/account/credit-cards.jsp"></parameter>
   		<classes>
			<class name="com.mcnichols.tests.production.MyAccountTest"></class>
   		</classes>
  	</test>
  	
  	<test name="Verify Third Party Services - Call Rail" preserve-order="true">
   		<classes>
			<class name="com.mcnichols.tests.vendor.VerifyCallRail"></class>
   		</classes>
  	</test>

</suite>
