<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd" >

<suite name="Production Regression Test" verbose="1">
	<parameter name="env" value="prod" />
	<parameter name="base.url" value="https://www.mcnichols.com/" />
	<parameter name="browser.name" value="chrome" /> <!-- Browser names: chrome, firefox -->
	<parameter name="browser.viewport" value="XL" /> <!-- Browser viewport options: XL, L, S, XS -->

  	<test name="Production - Place Order for Registered User" preserve-order="true">
   		<classes>
			<class name="com.mcnichols.tests.production.PlaceOrderForRegisteredUser"></class>
   		</classes>
  	</test>

</suite>
