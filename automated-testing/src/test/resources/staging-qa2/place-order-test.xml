<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd" >

<suite name="Staging QA2 Upgrade Regression Test" verbose="1">

	<parameter name="base.url" value="https://ww2-stage.mcnichols.com/" />
	<parameter name="browser.name" value="chrome" /> <!-- Browser names: chrome, firefox -->
	<parameter name="browser.viewport" value="XL" /> <!-- Browser viewport options: XL, L, S, XS -->

  	<test name="QA2 - Place Order for Registered User" preserve-order="true">
   		<classes>
			<class name="com.mcnichols.tests.PlaceOrderForRegisteredUser"></class>
   		</classes>
  	</test>
  	
  	<test name="QA2 - Express Checkout Order" preserve-order="true">
   		<classes>
			<class name="com.mcnichols.tests.ExpressCheckoutOrder"></class>
   		</classes>
  	</test>

</suite>
