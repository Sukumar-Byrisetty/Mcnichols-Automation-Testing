<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd" >

<suite name="Development Endpoint Regression Test" verbose="1">
	<parameter name="browser.name" value="chrome" /> <!-- Browser names: chrome, firefox -->
	<parameter name="browser.viewport" value="XL" /> <!-- Browser viewport options: XL, L, S, XS -->
	
	<!-- http://tpcq2atgapp01.mcnichols.com:7003 - START -->
	<test name="tpcq2atgapp01 - Place Order for Registered User" preserve-order="true">
		<parameter name="base.url" value="http://tpcq2atgapp01.mcnichols.com:7003/" />
   		<classes>
			<class name="com.mcnichols.tests.PlaceOrderForRegisteredUser"></class>
   		</classes>
  	</test>
  	
  	<test name="tpcq2atgapp01 - Place Quote for Guest User" preserve-order="true">
  		<parameter name="base.url" value="http://tpcq2atgapp01.mcnichols.com:7003/" />
   		<classes>
			<class name="com.mcnichols.tests.PlaceQuoteForGuestUser"></class>
   		</classes>
  	</test>
  	<!-- http://tpcq2atgapp01.mcnichols.com:7003 - END -->
  	
	<!-- http://tpcq2atgapp02.mcnichols.com:7003 - START -->
	<test name="tpcq2atgapp02 - Place Order for Registered User" preserve-order="true">
		<parameter name="base.url" value="http://tpcq2atgapp02.mcnichols.com:7003/" />
   		<classes>
			<class name="com.mcnichols.tests.PlaceOrderForRegisteredUser"></class>
   		</classes>
  	</test>
  	
  	<test name="tpcq2atgapp02 - Place Quote for Guest User" preserve-order="true">
  		<parameter name="base.url" value="http://tpcq2atgapp02.mcnichols.com:7003/" />
   		<classes>
			<class name="com.mcnichols.tests.PlaceQuoteForGuestUser"></class>
   		</classes>
  	</test>
  	<!-- http://tpcq2atgapp02.mcnichols.com:7003 - END -->
</suite>

