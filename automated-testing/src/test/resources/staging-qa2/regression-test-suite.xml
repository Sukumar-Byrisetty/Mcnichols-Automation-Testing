<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd" >

<suite name="Staging QA2 Website Regression Test Suite" verbose="1">

	<parameter name="env" value="qa2" />
	<parameter name="base.url" value="https://ww2-stage.mcnichols.com/" />
	<parameter name="browser.name" value="chrome" /> <!-- Browser names: chrome, firefox -->
	<parameter name="browser.viewport" value="XL" /> <!-- Browser viewport options: XL, L, S, XS -->
	
	<test name="QA2 - Place Order for Registered User" preserve-order="true">
   		<classes>
			<class name="com.mcnichols.tests.PlaceOrderForRegisteredUser"></class>
   		</classes>
  	</test>
  	
  	<test name="QA2 - Express Checkout Order" preserve-order="true">
   		<classes>
			<class name="com.mcnichols.tests.ExpressCheckoutOrder"></class>
   		</classes>
  	</test>
  	
  	<test name="QA2 - Place Quote for Registered User" preserve-order="true">
   		<classes>
			<class name="com.mcnichols.tests.PlaceQuoteForRegisteredUser"></class>
   		</classes>
  	</test>

  	<test name="QA2 - Place Quote for Guest User" preserve-order="true">
   		<classes>
			<class name="com.mcnichols.tests.PlaceQuoteForGuestUser"></class>
   		</classes>
  	</test>

  	<test name="QA2 - Browse and Search Test" preserve-order="true">
   		<classes>
			<class name="com.mcnichols.tests.BrowseAndSearchTest"></class>
   		</classes>
  	</test>
  	
  	<test name="QA2 - Product Page Trench Drain Test" preserve-order="true">
  		<parameter name="product.path" value="/trench-drain-systems/polycast-sup-reg-sup-system/polymer-concrete-f3pc188820" />
   		<classes>
			<class name="com.mcnichols.tests.sandbox.ProductPageTest"></class>
   		</classes>
  	</test>

  	<test name="QA2 - Verify Stair Treads Category Product Links Test" preserve-order="true">
  		<parameter name="category.path" value="/stair-treads" />
   		<classes>
			<class name="com.mcnichols.tests.VerifyPagesFromCategoryPage"></class>
   		</classes>
  	</test>
  	
  	<test name="QA2 - Site Map Page Test" preserve-order="true">
  		<parameter name="sitemap" value="/site-map"></parameter>
   		<classes>
			<class name="com.mcnichols.tests.SitemapPage"></class>
   		</classes>
  	</test>
  	
  	<test name="QA2 - My Account - Credit Card Page Test" preserve-order="true">
  		<parameter name="accountlanding" value="/account/account-landing.jsp"></parameter>
		<parameter name="accountCC" value="/account/credit-cards.jsp"></parameter>
   		<classes>
			<class name="com.mcnichols.tests.MyAccountTest"></class>
   		</classes>
  	</test>
  	
  	<test name="Verify Third Party Services - Call Rail" preserve-order="true">
   		<classes>
			<class name="com.mcnichols.tests.vendor.VerifyCallRail"></class>
   		</classes>
  	</test>

</suite>
